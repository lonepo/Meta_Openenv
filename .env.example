# CircuitSynth-SquareWave — Environment Variables
# Copy this file to .env and fill in your values before running inference.py
# These MUST be set before submission.

# ── Required by contest rules ──────────────────────────────────────────────

# The API endpoint for the LLM (OpenAI-compatible)
API_BASE_URL=https://api-inference.huggingface.co/v1/

# The model identifier to use for inference (e.g. Nemotron, Qwen, etc.)
MODEL_NAME=nvidia/Llama-3.1-Nemotron-70B-Instruct-HF

# Your Hugging Face API key / HF_TOKEN
HF_TOKEN=hf_your_token_here

# ── Optional overrides ─────────────────────────────────────────────────────

# Which task to run (squarewave-easy | squarewave-medium | squarewave-hard)
TASK_NAME=squarewave-easy

# Use mock simulator without ngspice (true | false)
MOCK_SIM=true

# Server port (default: 7860 for HF Spaces)
PORT=7860
